SITE_URL=http://localhost:3000

# Sentry (Error monitoring)
# Get your DSN from the Sentry project settings.
NEXT_PUBLIC_SENTRY_DSN=
SENTRY_AUTH_TOKEN=

# Resend (Email delivery)
# Get your API key from the Resend dashboard.
RESEND_API_KEY=

# Where contact form submissions should be delivered.
CONTACT_EMAIL=

# Must be a verified domain/sender in Resend.
# Example: Portfolio Contact <system@your-verified-domain.com>
CONTACT_FROM=
